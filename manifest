{
  "manifest_version": 3,
  "name": "Calorie Coach",
  "version": "1.0",
  "description": "Analyze meals, calories, and nutrition instantly while browsing.",
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "Calorie Coach"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  }
}
